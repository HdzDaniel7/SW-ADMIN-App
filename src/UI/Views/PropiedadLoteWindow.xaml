<ui:FluentWindow x:Class="SWDataExtractor.UI.Views.PropiedadLoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:conv="clr-namespace:SWDataExtractor.UI.Converters"
        Title="{Binding CabeceraTitulo}"
        Height="600" Width="900"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        WindowBackdropType="None"
        Background="{DynamicResource ApplicationBackgroundBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
        <conv:EstadoColorConverter    x:Key="EstadoColor"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{DynamicResource SwdeBarraTituloBrush}"
                BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1"/>
        <ui:TitleBar Grid.Row="0" Title="{Binding CabeceraTitulo}"/>
        <DockPanel Grid.Row="1" Margin="10">

        <!-- Formulario de entrada -->
        <Border DockPanel.Dock="Top" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="1"
                CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Propiedad:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox  Grid.Column="1" IsEditable="True" Margin="0,0,12,0"
                           ItemsSource="{Binding PropiedadesDisponibles}"
                           Text="{Binding PropiedadNombre, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Column="2" Text="Configuración:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox   Grid.Column="3" Margin="0,0,12,0"
                           Text="{Binding Configuracion, UpdateSourceTrigger=PropertyChanged}"
                           ToolTip="Vacío = nivel documento; relleno = nivel configuración"/>

                <TextBlock Grid.Column="4" Text="Valor nuevo:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox   Grid.Column="5" Margin="0,0,12,0"
                           Text="{Binding ValorNuevo, UpdateSourceTrigger=PropertyChanged}"/>

                <Button Grid.Column="6" Content="Calcular diff" Padding="12,4"
                        Command="{Binding CalcularDiffCommand}"/>
            </Grid>
        </Border>

        <!-- Barra de acciones -->
        <DockPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <Button DockPanel.Dock="Right" Content="Cerrar" Padding="14,4"
                    Margin="8,0,0,0" Click="Cerrar_Click"/>
            <Button DockPanel.Dock="Right" Content="Confirmar y escribir" Padding="14,4"
                    IsEnabled="{Binding PuedoConfirmar}"
                    Command="{Binding ConfirmarCommand}"/>
            <ProgressBar DockPanel.Dock="Right" Width="90" Height="14" Margin="8,0"
                         IsIndeterminate="True"
                         Visibility="{Binding EstaCargando, Converter={StaticResource BoolVis}}"/>
            <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Text="{Binding MensajeEstado}"/>
        </DockPanel>

        <!-- Pestañas: Vista previa / Resultados -->
        <TabControl>
            <TabItem Header="Vista previa de cambios">
                <DataGrid ItemsSource="{Binding Preview}"
                          AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding EsAdvertencia}" Value="True">
                                    <Setter Property="Background" Value="#FFF3CD"/>
                                    <Setter Property="Foreground" Value="#856404"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Archivo"        Binding="{Binding Archivo}"       Width="210"/>
                        <DataGridTextColumn Header="Propiedad"      Binding="{Binding Propiedad}"     Width="150"/>
                        <DataGridTextColumn Header="Valor anterior" Binding="{Binding ValorAnterior}" Width="190"/>
                        <DataGridTextColumn Header="Valor nuevo"    Binding="{Binding ValorNuevo}"    Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Resultados">
                <DataGrid ItemsSource="{Binding Resultados}"
                          AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Archivo"        Binding="{Binding Archivo}"       Width="210"/>
                        <DataGridTextColumn Header="Valor anterior" Binding="{Binding ValorAnterior}" Width="160"/>
                        <DataGridTextColumn Header="Valor nuevo"    Binding="{Binding ValorNuevo}"    Width="160"/>
                        <DataGridTemplateColumn Header="Resultado"  Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Resultado}"
                                               Foreground="{Binding Resultado, Converter={StaticResource EstadoColor}}"
                                               FontWeight="SemiBold" Margin="4,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Mensaje" Binding="{Binding Mensaje}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
        </DockPanel>
    </Grid>
</ui:FluentWindow>
