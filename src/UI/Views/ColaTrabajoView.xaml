<UserControl x:Class="SWDataExtractor.UI.Views.ColaTrabajoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:SWDataExtractor.UI.Converters">

    <UserControl.Resources>
        <conv:EstadoColorConverter x:Key="EstadoColor"/>
    </UserControl.Resources>

    <DockPanel>
        <ToolBar DockPanel.Dock="Top">
            <Button Command="{Binding RefrescarCommand}"          Content="↺ Refrescar"          Margin="2"/>
            <Button Command="{Binding LimpiarCompletadosCommand}" Content="🗑 Limpiar completados" Margin="2"/>
        </ToolBar>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding Resumen}"/>
            </StatusBarItem>
        </StatusBar>

        <DataGrid ItemsSource="{Binding Trabajos}"
                  AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Estado" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Estado}"
                                       Foreground="{Binding Estado, Converter={StaticResource EstadoColor}}"
                                       FontWeight="SemiBold" Margin="4,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Tipo"         Binding="{Binding Tipo}"              Width="80"/>
                <DataGridTextColumn Header="Archivo"      Binding="{Binding Archivo.Nombre}"    Width="200"/>
                <DataGridTextColumn Header="Encolado"     Binding="{Binding FechaEncolado}"     Width="160"/>
                <DataGridTextColumn Header="Duración (ms)" Binding="{Binding DuracionMs}"       Width="100"/>
                <DataGridTextColumn Header="Intentos"     Binding="{Binding Intentos}"          Width="65"/>
                <DataGridTextColumn Header="Mensaje"      Binding="{Binding Mensaje}"           Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
