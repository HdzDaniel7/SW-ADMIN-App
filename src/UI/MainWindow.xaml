<ui:FluentWindow x:Class="SWDataExtractor.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:conv="clr-namespace:SWDataExtractor.UI.Converters"
        Title="SWDataExtractor" Height="820" Width="1440" MinHeight="480" MinWidth="720"
        WindowStartupLocation="CenterScreen"
        WindowBackdropType="None"
        Background="{DynamicResource ApplicationBackgroundBrush}">

    <ui:FluentWindow.Resources>
        <conv:IndiceAVisibilidadConverter x:Key="IndiceAVisibilidad"/>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>

        <!-- Ítem de navegación del sidebar: ícono + texto, con estado seleccionado marcado
             por color de acento (evita depender de la fuente de íconos Segoe Fluent, que no
             podemos verificar en este entorno; se usan los mismos glifos ya usados en la app). -->
        <Style x:Key="ItemSidebar" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="14,11"/>
            <Setter Property="Margin" Value="6,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="3,0,0,0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentFillColorSecondaryBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorSecondaryBrush}"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Franja de título+menú con fondo temado propio (nunca negro: sin esto, el
             backdrop de la ventana podía dejar esta zona sin pintar) -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource SwdeBarraTituloBrush}"
                BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"/>

        <ui:TitleBar Grid.Row="0" Title="SWDataExtractor"/>

        <!-- Menú -->
        <Menu Grid.Row="1">
            <MenuItem Header="_Archivo">
                <MenuItem Header="_Exportar propiedades…" Click="ExportarPropiedades_Click"/>
                <Separator/>
                <MenuItem Header="_Salir" Click="Salir_Click"/>
            </MenuItem>
            <MenuItem Header="_Herramientas">
                <MenuItem Header="_Configuración…" Click="Configuracion_Click"/>
                <Separator/>
                <MenuItem Header="Crear acceso _directo en el escritorio" Click="CrearAccesoDirecto_Click"/>
            </MenuItem>
            <MenuItem Header="_Ayuda">
                <MenuItem Header="_Acerca de…" Click="AcercaDe_Click"/>
            </MenuItem>
        </Menu>

        <!-- Cuerpo: sidebar de navegación + contenido de la sección activa -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="176"/>
                <ColumnDefinition Width="*" MinWidth="360"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Alternar Plano técnico (claro) / Consola (oscuro) — se recuerda entre arranques -->
                    <Button DockPanel.Dock="Bottom" Command="{Binding AlternarTemaCommand}"
                            HorizontalContentAlignment="Left" Margin="8" Padding="10,8"
                            Background="Transparent" BorderThickness="0">
                        <Grid>
                            <StackPanel Orientation="Horizontal" Visibility="{Binding TemaOscuro, Converter={StaticResource BoolVis}}">
                                <TextBlock Text="☀" FontSize="14" Margin="0,0,8,0"/>
                                <TextBlock Text="Modo claro" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TemaOscuro}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="🌙" FontSize="14" Margin="0,0,8,0"/>
                                <TextBlock Text="Modo oscuro" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Button>

                    <ListBox x:Name="SidebarList" BorderThickness="0" Background="Transparent"
                             SelectedIndex="{Binding SeccionActiva}" Margin="0,8">
                        <ListBoxItem Style="{StaticResource ItemSidebar}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📁" FontSize="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Archivos" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Style="{StaticResource ItemSidebar}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🧭" FontSize="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Explorador" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Style="{StaticResource ItemSidebar}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚙" FontSize="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Cola de trabajos" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Style="{StaticResource ItemSidebar}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📋" FontSize="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Historial" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ListBoxItem>
                    </ListBox>
                </DockPanel>
            </Border>

            <Grid Grid.Column="1">
                <ContentPresenter x:Name="ArchivosViewControl"
                    Visibility="{Binding SeccionActiva, Converter={StaticResource IndiceAVisibilidad}, ConverterParameter=0}"/>
                <ContentPresenter x:Name="ExploradorViewControl"
                    Visibility="{Binding SeccionActiva, Converter={StaticResource IndiceAVisibilidad}, ConverterParameter=1}"/>
                <ContentPresenter x:Name="ColaViewControl"
                    Visibility="{Binding SeccionActiva, Converter={StaticResource IndiceAVisibilidad}, ConverterParameter=2}"/>
                <ContentPresenter x:Name="HistorialViewControl"
                    Visibility="{Binding SeccionActiva, Converter={StaticResource IndiceAVisibilidad}, ConverterParameter=3}"/>
            </Grid>
        </Grid>

        <!-- Notificaciones no bloqueantes (ver ServicioNotificaciones) — flotan sobre todo el contenido -->
        <ui:SnackbarPresenter x:Name="RootSnackbar" Grid.Row="0" Grid.RowSpan="3"
                              HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,16,16"/>
    </Grid>
</ui:FluentWindow>
