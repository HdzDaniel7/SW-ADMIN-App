  "permissions": {
    "deny": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git tag:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(git merge:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git stash drop:*)",
      "Bash(git branch -D:*)",
      "Bash(rm -rf:*)",
      "Bash(dotnet ef database drop:*)"
